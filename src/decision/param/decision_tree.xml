<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="3" main_tree_to_execute="main_tree">
    <BehaviorTree ID="main_tree">
        <ReactiveSequence>
            <GameStart get_start="{game_start}" update_start="{game_start}"/>
            <UpdateStatus hp_status="{hp_status}"
                          ctlarea_status="{ctlarea_status}"
                          enermy_observed="{enermy_observed}"
                          enermy_onhighland="{enermy_onhighland}"

                          add_blood="{add_blood}"
                          pos_1="{pos_1}"
                          pos_2="{pos_2}"
                          pos_3="{pos_3}"
                          pos_4="{pos_2}"
                          pos_5="{pos_5}"
                          attack_pos="{attack_pos}"
                          idle_pos="{idle_pos}"/>
            <WhileDoElse>
                <CheckStatus get_status="{hp_status}"/>
                <GetToPosition target_position="{add_blood}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <ReactiveSequence>
                    <GetToPosition target_position="{pos_1}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    <Switch3 variable="{ctlarea_status}" case_1="enermy_control" case_2="myteam_control" case_3="none_control">
                        <SubTree ID="enermy_control" __shared_blackboard="true"/>
                        <SubTree ID="myteam_control" __shared_blackboard="true"/>
                        <SubTree ID="none_control" __shared_blackboard="true"/>
                        <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    </Switch3>
                </ReactiveSequence>
            </WhileDoElse>
        </ReactiveSequence>
    </BehaviorTree>

    <BehaviorTree ID="enermy_control">
        <ReactiveSequence>
            <GetToPosition target_position="{pos_2}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
            <WhileDoElse>
                <CheckStatus get_status="{enermy_observed}"/>
                <GetToPosition target_position="{attack_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
            </WhileDoElse>
        </ReactiveSequence>
    </BehaviorTree>

    <BehaviorTree ID="myteam_control">
        <WhileDoElse>
            <CheckStatus get_status="{enermy_onhighland}"/>
            <ReactiveSequence>
                <GetToPosition target_position="{pos_4}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <WhileDoElse>
                    <CheckStatus get_status="{enermy_observed}"/>
                    <GetToPosition target_position="{attack_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                </WhileDoElse>
            </ReactiveSequence>
            <ReactiveSequence>
                <GetToPosition target_position="{pos_3}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <WhileDoElse>
                    <CheckStatus get_status="{enermy_observed}"/>
                    <GetToPosition target_position="{attack_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                </WhileDoElse>
            </ReactiveSequence>
        </WhileDoElse>
    </BehaviorTree>

    <BehaviorTree ID="none_control">
        <WhileDoElse>
            <CheckStatus get_status="{enermy_onhighland}"/>
            <ReactiveSequence>
                <GetToPosition target_position="{pos_4}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <WhileDoElse>
                    <CheckStatus get_status="{enermy_observed}"/>
                    <GetToPosition target_position="{attack_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                </WhileDoElse>
            </ReactiveSequence>
            <ReactiveSequence>
                <GetToPosition target_position="{pos_5}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                <WhileDoElse>
                    <CheckStatus get_status="{enermy_observed}"/>
                    <GetToPosition target_position="{attack_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                    <GetToPosition target_position="{idle_pos}" get_curpos="{cur_pos}" update_curpos="{cur_pos}"/>
                </WhileDoElse>
            </ReactiveSequence>
        </WhileDoElse>
    </BehaviorTree>

    <TreeNodesModel>

        <Condition ID="GameStart">
            <input_port name="get_start">whether the game started</input_port>
            <output_port name="update_start">update the game process</output_port>
        </Condition>

        <Condition ID="CheckStatus">
            <input_port name="get_status">the status of a factor</input_port>
        </Condition>

        <Action ID="UpdateStatus">
            <!-- 各种状态 -->
            <output_port name="hp_status">hp status</output_port>
            <output_port name="ctlarea_status">who takes the control area, 1:enermy 2:me 3:none</output_port>
            <output_port name="enermy_observed">enermy observed</output_port>
            <output_port name="enermy_onhighland">whether enermy on highland</output_port>
            <!-- 各种位置 -->
            <output_port name="add_blood">the position of home</output_port>
            <output_port name="pos_1">pos 1</output_port>
            <output_port name="pos_2">pos 2</output_port>
            <output_port name="pos_3">pos 3</output_port>
            <output_port name="pos_4">pos 4</output_port>
            <output_port name="pos_5">pos 5</output_port>
            <output_port name="attack_pos">attack pos</output_port>
            <output_port name="idle_pos">idle pos</output_port>
        </Action>

        <Action ID="GetToPosition">
            <input_port name="target_position">position to go</input_port>
            <input_port name="get_curpos">get the current position</input_port>
            <output_port name="update_curpos">update current position</output_port>
        </Action>

    </TreeNodesModel>
</root>